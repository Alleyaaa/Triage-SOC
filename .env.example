# SOC Triage Dashboard — Environment Variables
# Copy this file to .env and fill in the values

# ─── Database (required) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://soc_user:soc_password@localhost:5432/soc_triage

# For Docker Compose, these are used to build DATABASE_URL automatically:
POSTGRES_USER=soc_user
POSTGRES_PASSWORD=soc_password
POSTGRES_DB=soc_triage

# ─── Authentication ───────────────────────────────────────────────────────────
SESSION_SECRET=change-me-to-a-long-random-string-in-production

# ─── AI — Gemini (optional, needed if not using n8n) ─────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ─── n8n SOAR (optional) ─────────────────────────────────────────────────────
# If using n8n, configure the webhook URL in the dashboard Settings page.
# The webhook URL is saved to the database — no env var needed.
# n8n itself needs GEMINI_API_KEY set in its own environment variables.
